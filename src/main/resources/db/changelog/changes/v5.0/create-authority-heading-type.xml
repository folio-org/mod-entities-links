  <changeSet id="MODELINKS-401@@schema-create-table-authority-heading-type" author="pavlo_smahin">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="authority_heading_type"/>
      </not>
    </preConditions>

    <comment>Create authority_heading_type table</comment>

    <createTable tableName="authority_heading_type">
      <column name="id" type="UUID">
        <constraints nullable="false" primaryKey="true" primaryKeyName="pk_authority_heading_type"/>
      </column>
      <column name="name" type="varchar(250)">
        <constraints nullable="false" unique="true" uniqueConstraintName="authority_heading_type_name_unq"/>
      </column>
      <column name="code" type="varchar(100)">
        <constraints nullable="false" unique="true" uniqueConstraintName="authority_heading_type_code_unq"/>
      </column>
      <column name="queryable" type="boolean" defaultValueBoolean="true">
        <constraints nullable="false"/>
      </column>
    </createTable>
  </changeSet>

