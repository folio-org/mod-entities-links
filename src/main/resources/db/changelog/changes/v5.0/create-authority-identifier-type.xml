  <changeSet id="MODELINKS-401@@schema-create-table-authority-identifier-type" author="pavlo_smahin">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="authority_identifier_type"/>
      </not>
    </preConditions>

    <comment>Create authority_identifier_type table</comment>

    <createTable tableName="authority_identifier_type">
      <column name="id" type="UUID">
        <constraints nullable="false" primaryKey="true" primaryKeyName="pk_authority_identifier_type"/>
      </column>
      <column name="name" type="varchar(250)">
        <constraints nullable="false" unique="true" uniqueConstraintName="authority_identifier_type_name_unq"/>
      </column>
      <column name="code" type="varchar(100)">
        <constraints nullable="false" unique="true" uniqueConstraintName="authority_identifier_type_code_unq"/>
      </column>
      <column name="source" type="varchar(100)">
        <constraints nullable="false"/>
      </column>
      <column name="created_date" type="DATETIME">
        <constraints nullable="false"/>
      </column>
      <column name="updated_date" type="DATETIME">
        <constraints nullable="false"/>
      </column>
      <column name="created_by_user_id" type="uuid">
        <constraints nullable="false"/>
      </column>
      <column name="updated_by_user_id" type="uuid">
        <constraints nullable="false"/>
      </column>
    </createTable>
  </changeSet>

